      interval = setInterval(
        () => {
          startAnimation();
        },
        dynamicTitles.length * dynamicIntervalLength * 1000,
      );
    } else if (interval) {
      stopAnimation();
      window.clearInterval(interval);
    }
  });

  observer.observe(dynamicTitleBlade);

  let resizeTimer;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      applyListContainerHeight();
    }, 1000);
  });
})();</script>  <div class="mt-10 md:mt-12" style="--forcedTabSwitchInterval: 15;"> <div role="tablist" class="flex mb-4 sm:mx-4 md:mx-5 overflow-x-auto" data-qa="TabTitlesContainer-snv63"> <div data-qa="TabTitleEntry-snv63" class="whitespace-nowrap first:lg:pe-6 first:md:pe-5 first:sm:pe-4 last:lg:ps-6 last:md:ps-5 last:sm:ps-4"> <div role="tab" aria-selected="true" data-qa="tab-title-snv63-0" class="active md:min-w-[102px]">  <div data-qa="FragmentTitle" class="text-start col-span-4">  <h4 data-qa="Heading" class="text-[1rem] me-4 font-normal leading-none cursor-pointer opacity-60 leading-[110%] ar:leading-snug heading-4">Connect</h4>  </div>  <div class="w-full bg-gray-3 rounded-md" data-qa="tab-progress-container-bar-snv63-0"> <div class="w-full bg-gradient-to-mango from-ruby" data-qa="tab-progress-bar-snv63-0"></div> </div> </div> </div><div data-qa="TabTitleEntry-snv63" class="whitespace-nowrap first:lg:pe-6 first:md:pe-5 first:sm:pe-4 last:lg:ps-6 last:md:ps-5 last:sm:ps-4 lg:px-6 md:px-5 sm:px-4"> <div role="tab" aria-selected="false" data-qa="tab-title-snv63-1" class="md:min-w-[102px]">  <div data-qa="FragmentTitle" class="text-start col-span-4">  <h4 data-qa="Heading" class="text-[1rem] me-4 font-normal leading-none cursor-pointer opacity-60 leading-[110%] ar:leading-snug heading-4">Protect</h4>  </div>  <div class="w-full bg-gray-3 rounded-md" data-qa="tab-progress-container-bar-snv63-1"> <div class="w-full bg-gradient-to-mango from-ruby" data-qa="tab-progress-bar-snv63-1"></div> </div> </div> </div><div data-qa="TabTitleEntry-snv63" class="whitespace-nowrap first:lg:pe-6 first:md:pe-5 first:sm:pe-4 last:lg:ps-6 last:md:ps-5 last:sm:ps-4"> <div role="tab" aria-selected="false" data-qa="tab-title-snv63-2" class="md:min-w-[102px]">  <div data-qa="FragmentTitle" class="text-start col-span-4">  <h4 data-qa="Heading" class="text-[1rem] me-4 font-normal leading-none cursor-pointer opacity-60 leading-[110%] ar:leading-snug heading-4">Build</h4>  </div>  <div class="w-full bg-gray-3 rounded-md" data-qa="tab-progress-container-bar-snv63-2"> <div class="w-full bg-gradient-to-mango from-ruby" data-qa="tab-progress-bar-snv63-2"></div> </div> </div> </div> </div> <div data-qa="contentContainer" class="contentBorder templateLayoutTwoColumn" style="--forcedTabSwitchInterval: 15;"> <div style="--forcedTabSwitchInterval: 15;"> <div role="tabpanel" data-qa="tab-entry-snv63-0" class="overflow-hidden pb-6 hidden" aria-hidden="true" data-astro-cid-upvejypx>  <section data-qa="TemplateLayoutTwoColumn" class="py-0">   <div class="container">  <div>  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:max-lg:grid-cols-1 md:gap-y-8"> <div data-column="0" class="flex flex-col gap-8 md:col-span-1 justify-center left-col flex flex-col items-start h-full gap-6 md:gap-8">  <div data-qa="FragmentTitle" class="text-start col-span-4">  <h3 data-qa="Heading" class="leading-[110%] ar:leading-snug heading-3">Connect users and apps securely</h3>  </div>  <div data-qa="FragmentMarkdown"> <div class="space-y-4"><p>SASE keeps hybrid work productive everywhere, securing human and AI agent communications.</p>
